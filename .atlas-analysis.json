  "keyFeatures": [
    "Exact geodesic distance computation using MMP algorithm",
    "Fast marching geodesic approximation with per-face speed control",
    "Isocurve (isolines) extraction on scalar fields defined on triangular meshes",
    "Incremental isotropic remeshing (C++ accelerated)",
    "Mesh cutting along vertex chains",
    "Mesh splitting by inserting new vertices on edges",
    "Centroidal Voronoi Tessellation (CVT) on the unit sphere",
    "Vertex colormap visualization of scalar fields",
    "Face-face and vertex-vertex graph construction",
    "Connected component splitting",
    "Polyline reading/writing in Wavefront OBJ format",
    "ShapeOp partial binding for shape deformation"
  ],
  "publicApiSurface": [
